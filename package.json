{
	"name": ".bootstrap-scaffold",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "next build",
		"check": "biome check .",
		"check:unsafe": "biome check --write --unsafe .",
		"check:write": "biome check --write .",
		"ci": "biome check . && tsc --noEmit && vitest run && next build",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:seed": "tsx --env-file=.env src/server/db/seed.ts",
		"db:studio": "drizzle-kit studio",
		"dev": "next dev --turbo",
		"preview": "next build && next start",
		"start": "next start",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@base-ui/react": "^1.5.0",
		"@libsql/client": "^0.14.0",
		"@t3-oss/env-nextjs": "^0.12.0",
		"@tanstack/react-query": "^5.69.0",
		"@trpc/client": "^11.0.0",
		"@trpc/react-query": "^11.0.0",
		"@trpc/server": "^11.0.0",
		"bcryptjs": "^3.0.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.41.0",
		"lucide-react": "^1.17.0",
		"next": "^15.2.3",
		"next-auth": "^5.0.0-beta.31",
		"next-themes": "^0.4.6",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"server-only": "^0.0.1",
		"shadcn": "^4.11.0",
		"sonner": "^2.0.7",
		"superjson": "^2.2.1",
		"tailwind-merge": "^3.6.0",
		"tuyapi": "^7.7.1",
		"tw-animate-css": "^1.4.0",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.5",
		"@tailwindcss/postcss": "^4.0.15",
		"@types/bcryptjs": "^2.4.6",
		"@types/node": "^20.14.10",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"drizzle-kit": "^0.30.5",
		"postcss": "^8.5.3",
		"tailwindcss": "^4.0.15",
		"tsx": "^4.22.4",
		"typescript": "^5.8.2",
		"vitest": "^4.1.8"
	},
	"ct3aMetadata": {
		"initVersion": "7.40.0"
	},
	"packageManager": "npm@11.13.0"
}
